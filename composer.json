{
    "name": "bensomething/craft-tabler-icons",
    "description": "An icon picker field for Tabler icons.",
    "type": "craft-plugin",
    "license": "MIT",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "plugin",
        "icons",
        "tabler"
    ],
    "support": {
        "issues": "https://github.com/bensomething/craft-tabler-icons/issues",
        "source": "https://github.com/bensomething/craft-tabler-icons"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "bensomething\\tabler\\": "src/"
        }
    },
    "extra": {
        "handle": "tabler",
        "name": "Tabler Icons",
        "developer": "Ben Smith",
        "developerUrl": "https://bensomething.com",
        "class": "bensomething\\tabler\\Plugin",
        "documentationUrl": "https://github.com/bensomething/craft-tabler-icons",
        "changelogUrl": "https://raw.githubusercontent.com/bensomething/craft-tabler-icons/develop/CHANGELOG.md"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main"
    },
    "scripts": {
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --ansi --fix",
        "phpstan": "phpstan --memory-limit=1G"
    }
}
